<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LSL.ViewModels"
             xmlns:controls="clr-namespace:LSL.Controls"
             x:DataType="vm:ShellViewModel"
             mc:Ignorable="d" d:DesignWidth="1050" d:DesignHeight="600"
             x:Class="LSL.Views.Download.ASViews.AddFolder">
    <ScrollViewer>
        <StackPanel>
            <controls:MyCard Text="从文件夹添加现有服务器">
                <StackPanel Margin="25,10,25,15">
                    <StackPanel Margin="30,50,0,5">
                        <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">服务器核心路径</TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" Width="300"
                                     Text="{Binding FormViewModel.CorePath}" />
                            <controls:MyButton VerticalAlignment="Center" HorizontalAlignment="Left"
                                               Command="{Binding FormViewModel.SelectFolderCoreCmd}" Width="100"
                                               Height="30"
                                               Margin="10,0,10,0">
                                选择核心
                            </controls:MyButton>
                        </StackPanel>
                        <TextBlock Margin="0,0,10,0" FontSize="10" Foreground="Gray">核心文件所在的目录将被视作该服务器的根目录，并且整个服务器将被拷贝到LSL服务器文件夹中。</TextBlock>
                        <TextBlock Margin="0,0,10,0" FontSize="13" Foreground="DarkGray"
                                   Text="{Binding FormViewModel.EditingConfig.ServerPath}" />
                    </StackPanel>
                    <StackPanel Margin="30,10,0,5">
                        <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">服务器名称</TextBlock>
                        <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" Width="300"
                                 Text="{Binding FormViewModel.EditingConfig.ServerName}" />
                    </StackPanel>
                    <StackPanel Margin="30,10,0,5">
                        <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">内存大小</TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" Width="100"
                                     Text="{Binding FormViewModel.EditingConfig.MinMemory}" />
                            <TextBlock VerticalAlignment="Center" Margin="10,0,10,0">MB ~</TextBlock>
                            <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" Width="100"
                                     Text="{Binding FormViewModel.EditingConfig.MaxMemory}" />
                            <TextBlock VerticalAlignment="Center" Margin="10,0,10,0">MB</TextBlock>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Margin="30,10,0,5">
                        <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">Java路径</TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBox HorizontalAlignment="Left" Width="450"
                                     Text="{Binding FormViewModel.EditingConfig.JavaPath}" />
                            <controls:MyTip Text="出于性能考虑，不会即时检查目标可执行文件是否为Java。在提交表单时将会进行检查。"/>
                        </StackPanel>
                        <TextBlock Margin="0,0,10,0" FontSize="10" Foreground="Gray">从搜索到的Java中选择</TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox Name="Java"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"
                                      Width="300"
                                      ItemsSource="{Binding FormViewModel.JavaList}"
                                      SelectedIndex="{Binding FormViewModel.SelectedJavaIndex}" />
                            <controls:MyButton Name="GetJavaBtn" VerticalAlignment="Center" HorizontalAlignment="Left"
                                               Width="100"
                                               Height="30" Margin="10,0,0,0" Command="{Binding ConfigVM.SearchJava}">
                                搜索Java
                            </controls:MyButton>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Margin="30,10,0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">附加JVM参数</TextBlock>
                            <controls:MyTip Text="除了内存与jar文件外，其他你要添加的JVM参数，例如指定使用ZGC。支持使用空格或换行来分割参数。"/>
                        </StackPanel>
                        <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" Width="300" MinHeight="300"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Text="{Binding FormViewModel.ExtraJvmArgs}" />
                    </StackPanel>
                    <CheckBox Margin="0,10,0,5" IsChecked="{Binding FormViewModel.EditingConfig.StatusMonitoring}">服务器上线检测</CheckBox>
                    <controls:MyButton Name="Confirm" VerticalAlignment="Center" HorizontalAlignment="Left" Width="100"
                                       Height="30" Margin="30,10,0,5" ColorType="Highlight"
                                       Command="{Binding FormViewModel.AddExistedServerCmd}">
                        确认添加
                    </controls:MyButton>
                </StackPanel>
            </controls:MyCard>
        </StackPanel>
    </ScrollViewer>
</UserControl>