<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LSL.ViewModels"
             xmlns:controls="clr-namespace:LSL.Controls"
             x:DataType="vm:ShellViewModel"
             mc:Ignorable="d" d:DesignWidth="1050" d:DesignHeight="600"
             x:Class="LSL.Views.Settings.CommonSettings">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <controls:MyCard Text="常规设置">
                <StackPanel Margin="25,40,23,15">
                    <CheckBox Margin="0,10,0,5" IsChecked="{Binding ConfigVM.DaemonConfigs.EndServerOnClose}">关闭启动器时终止服务器进程</CheckBox>
                    <CheckBox Margin="0,5,0,5" IsChecked="{Binding ConfigVM.DesktopConfigs.EnableDaemonKeepRunning}">保持后台进程开启</CheckBox>
                    <CheckBox Margin="0,5,0,5" IsChecked="{Binding ConfigVM.DesktopConfigs.EnableTray}">关闭时最小化到托盘</CheckBox>
                </StackPanel>
            </controls:MyCard>
            
            <controls:MyCard Text="下载设置">
                <StackPanel Margin="25,40,23,15">
                    <DockPanel Margin="0,10,0,5">
                        <TextBlock Margin="0,-3,10,0" VerticalAlignment="Center" Text="下载线程数" />
                        <Slider x:Name="DownloadThreads"
                                Maximum="64"
                                Minimum="1"
                                Value="{Binding ConfigVM.DaemonConfigs.DownloadThreads}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Width="400"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="0,-20,10,-20" />
                        <TextBlock Text="{Binding #DownloadThreads.Value}" Margin="10,-3,10,0"
                                   VerticalAlignment="Center" FontWeight="Bold" />
                    </DockPanel>
                    <DockPanel Margin="0,10,0,5">
                        <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="下载限速" />
                        <TextBox Width="150" Text="{Binding ConfigVM.DaemonConfigs.DownloadLimitKBytes}" />
                        <TextBlock Text="KB/s，0表示不限速" Margin="10,0,10,0" VerticalAlignment="Center" />
                    </DockPanel>
                </StackPanel>
            </controls:MyCard>

            <controls:MyCard Text="Java设置">
                <StackPanel Margin="25,40,23,15">
                    <TreeDataGrid Margin="0,5,0,5"
                                  Source="{Binding ConfigVM.JavaVersions}"
                                  CanUserResizeColumns="False"
                                  CanUserSortColumns="False"
                                  Width="800"
                                  HorizontalAlignment="Left">
                        <TreeDataGrid.Styles>
                            <Style Selector="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap" />
                            </Style>
                        </TreeDataGrid.Styles>
                    </TreeDataGrid>
                    <DockPanel Margin="0,5,0,5">
                        <controls:MyButton ColorType="Highlight" HorizontalAlignment="Left" Margin="0,0,10,0"
                                           Width="120" Height="30" Command="{Binding ConfigVM.SearchJava}">
                            查找可用Java
                        </controls:MyButton>
                        <!--
					<controls:MyButton HorizontalAlignment="Left" Margin="0,0,10,0" Width="120" Height="30">手动选择Java</local:MyButton>-->
                    </DockPanel>
                </StackPanel>
            </controls:MyCard>
            
            <controls:MyCard Text="服务器设置">
                <StackPanel Margin="25,40,23,15">
                    <CheckBox Margin="0,10,0,5" IsChecked="{Binding ConfigVM.DaemonConfigs.AutoEula}">自动同意EULA</CheckBox>
                    <StackPanel Margin="30,10,0,5">
                        <TextBlock VerticalAlignment="Center" Margin="0,0,10,0">默认附加JVM参数</TextBlock>
                        <TextBox VerticalAlignment="Center" HorizontalAlignment="Left" Width="300" MinHeight="300"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Text="{Binding ConfigVM.UniversalJvmPrefix}" />
                    </StackPanel>
                </StackPanel>
            </controls:MyCard>
        </StackPanel>
    </ScrollViewer>
</UserControl>