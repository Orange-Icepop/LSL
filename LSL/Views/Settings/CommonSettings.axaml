<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LSL.ViewModels"
             xmlns:controls="clr-namespace:LSL.Controls"
             x:DataType="vm:ShellViewModel"
             mc:Ignorable="d" d:DesignWidth="1050" d:DesignHeight="600"
             x:Class="LSL.Views.Settings.CommonSettings">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <controls:MyCard Text="常规设置">
                <StackPanel Margin="25,40,23,15">
                    <CheckBox Margin="0,10,0,5" IsChecked="{Binding ConfigVM.DaemonConfigs.AutoEula}">自动同意EULA</CheckBox>
                    <CheckBox Margin="0,5,0,5" IsChecked="{Binding ConfigVM.DaemonConfigs.EndServerOnClose}">关闭启动器时终止服务器进程</CheckBox>
                    <CheckBox Margin="0,5,0,5" IsChecked="{Binding ConfigVM.DesktopConfigs.EnableDaemonKeepRunning}">保持后台进程开启</CheckBox>
                </StackPanel>
            </controls:MyCard>

            <controls:MyCard Text="Java设置">
                <StackPanel Margin="25,40,23,15">
                    <TreeDataGrid Margin="0,5,0,5"
                                  Source="{Binding ConfigVM.JavaVersions}"
                                  CanUserResizeColumns="False"
                                  CanUserSortColumns="False"
                                  Width="800"
                                  HorizontalAlignment="Left">
                        <TreeDataGrid.Styles>
                            <Style Selector="TextBlock">
                                <Setter Property="TextWrapping" Value="Wrap" />
                            </Style>
                        </TreeDataGrid.Styles>
                    </TreeDataGrid>
                    <DockPanel Margin="0,5,0,5">
                        <controls:MyButton ColorType="Highlight" HorizontalAlignment="Left" Margin="0,0,10,0"
                                           Width="120" Height="30" Command="{Binding ConfigVM.SearchJava}">
                            查找可用Java
                        </controls:MyButton>
                        <!--
					<controls:MyButton HorizontalAlignment="Left" Margin="0,0,10,0" Width="120" Height="30">手动选择Java</local:MyButton>-->
                    </DockPanel>
                </StackPanel>
            </controls:MyCard>
        </StackPanel>
    </ScrollViewer>
</UserControl>